# ── Database ────────────────────────────────────────────────────────────────
# Full PostgreSQL connection string used by the backend.
# When running via docker-compose this is built automatically from the
# POSTGRES_* vars below — you only need to set this for external DB hosting.
DATABASE_URL=postgresql://devchat:devchat@localhost:5432/devchat

# PostgreSQL credentials (used by the postgres docker-compose service)
POSTGRES_USER=devchat
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=devchat

# ── Auth ─────────────────────────────────────────────────────────────────────
# CHANGE THIS in production — generate with: openssl rand -hex 32
SECRET_KEY=change_me_generate_random_64_chars
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── CORS ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost
ENABLE_DOCS=false

# Basic abuse protection
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_DEFAULT_MAX=240
RATE_LIMIT_AUTH_MAX=15
RATE_LIMIT_UPLOAD_MAX=30
RATE_LIMIT_MESSAGE_MAX=120

# Upload limits
MAX_USER_STORAGE_BYTES=262144000
MAX_ATTACHMENTS_PER_MESSAGE=10

# Welcome email (SMTP)
WELCOME_EMAIL_ENABLED=false
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=your-smtp-login@smtp-brevo.com
SMTP_PASSWORD=your-smtp-key
SMTP_FROM_EMAIL=verified-sender@example.com
SMTP_FROM_NAME=DevChat
SMTP_USE_TLS=true
